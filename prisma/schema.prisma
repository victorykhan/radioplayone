datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  role         String        @default("VIEWER") // ADMIN, DJ, PRODUCER, VIEWER
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]
}

model Track {
  id           Int                @id @default(autoincrement())
  title        String
  artist       String?
  album        String?
  duration     Float              // in seconds
  fileHash     String             @unique // SHA256 of the audio file to dedup
  filePath     String             // path to the file on disk
  fileType     String             @default("SONG") // SONG, AD, JINGLE, STATION_ID, FILLER
  coverArtUrl  String?
  isDeleted    Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  categories   TrackCategory[]    // many-to-many
  playlists    PlaylistTrack[]
  fallbackItem FallbackPoolItem?
  playLogs     PlayLog[]
  adTrack      AdTrack?
  instantCarts InstantCart[]
  imagingElement ImagingElement?
  
  // Custom Playback Overrides
  volumeTrim   Float              @default(1.0)  // Volume multiplier (e.g. 0.8 to quiet, 1.2 to boost)
  cueStart     Float              @default(0.0)  // Skips silence at the start of file
  cueIntro     Float              @default(0.0)  // Talkover point (where vocals start, DJ voice fades down)
  cueOutro     Float              @default(0.0)  // Transition trigger point (where next song starts fading in)
  cueEnd       Float              @default(0.0)  // Cut off point (skips tail silence)
  fadeDuration Float?                            // Custom fade duration override in seconds
  isExplicit   Boolean            @default(false)
  
  // Musical Metadata
  bpm          Float?
  energy       Int?
  mood         String?
}

model TrackCategory {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  description String?
  parentId    Int?
  parent      TrackCategory?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  children    TrackCategory[] @relation("SubCategories")
  tracks      Track[]         // many-to-many
}

model Playlist {
  id             Int             @id @default(autoincrement())
  name           String
  isScheduled    Boolean         @default(false)
  isFallbackPool Boolean         @default(false) // Custom flag for multiple fallback pools
  scheduleTime   String?         // HH:MM format or Cron expression
  duration       Float           @default(0.0) // sum of track durations
  isLooping      Boolean         @default(true)
  color          String?         // Hex color for calendar
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tracks         PlaylistTrack[]
  scheduleSlots  ScheduleSlot[]  // Calendar based slots
}

model PlaylistTrack {
  id         Int      @id @default(autoincrement())
  playlistId Int
  trackId    Int
  position   Int      // Ordering position (0, 1, 2...)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, position]) // ensure unique positions within a playlist
}

model ScheduleSlot {
  id          String   @id @default(uuid())
  playlistId  Int
  startAt     DateTime // Saved as UTC (converted from station timezone)
  endAt       DateTime // Saved as UTC (converted from station timezone)
  color       String?  // Hex override color for calendar
  createdAt   DateTime @default(now())

  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([startAt, endAt])
}

model FallbackPoolItem {
  id        Int      @id @default(autoincrement())
  trackId   Int      @unique
  priority  Int      @default(0) // Higher = played first
  createdAt DateTime @default(now())

  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model PlayLog {
  id             Int      @id @default(autoincrement())
  trackId        Int
  playedAt       DateTime @default(now())
  durationPlayed Float    // actual seconds played before transitioning/stopping
  status         String   @default("COMPLETED") // COMPLETED, INTERRUPTED
  listenerCount  Int      @default(0)
  wasAd          Boolean  @default(false)

  track          Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  details   String?
  timestamp DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model SystemSetting {
  key   String @id // e.g. "theme", "station_info"
  value String // JSON string containing settings
}

model ListenerSession {
  id             String    @id @default(uuid())
  icecastId      String    // The unique ID assigned by Icecast
  ipHash         String    // SHA-256 hash of IP (For GDPR/Privacy Compliance)
  country        String    @default("Unknown") // Geo-IP country code (e.g., "CA", "US")
  city           String    @default("Unknown")
  latitude       Float?
  longitude      Float?
  userAgent      String?
  deviceType     String    @default("Desktop") // Desktop, Mobile, Smart Speaker, Media Player
  connectedAt    DateTime  @default(now())
  disconnectedAt DateTime?
  duration       Int?      // Connection duration in seconds

  @@index([connectedAt])
  @@index([disconnectedAt])
}

model Campaign {
  id                String    @id @default(uuid())
  clientName        String
  clientIndustry    String    // e.g. "Automotive", "Beverage"
  name              String    // e.g. "Summer Deal 2026"
  startDate         DateTime
  endDate           DateTime
  targetPlays       Int       // Total contracted plays
  currentPlays      Int       @default(0)
  targetImpressions Int       // Total contracted listener impressions
  cpc               Float     // Cost Per Play or Cost Per Impression (for revenue tracking)
  
  // Optimization Constraints
  dailyCap          Int       // Max plays per day
  hourlyCap         Int       // Max plays per hour
  validHoursStart   Int       @default(0)
  validHoursEnd     Int       @default(23)
  priority          Int       @default(1) // Priority scale weight (1 to 5)
  isActive          Boolean   @default(true)
  
  ads               AdTrack[]
}

model AdTrack {
  id          String   @id @default(uuid())
  trackId     Int      @unique
  campaignId  String
  
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model InstantCart {
  slot      Int      @id // 1 to 5
  trackId   Int
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model ImagingElement {
  id          String   @id @default(uuid())
  name        String
  type        String   // "INSTANT_CART", "SWEEPER", "STATION_ID", "DJ_DROP"
  trackId     Int      @unique
  slotNumber  Int?     // Hotkey mapping 1-12
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Transition & Matching Rules
  bpmMin      Float?
  bpmMax      Float?
  energyMin   Int?
  energyMax   Int?
  mood        String?
  playMode    String   @default("OVERLAY") // "OVERLAY" or "TRANSITION"

  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model RemoteBroadcaster {
  id        String   @id @default(uuid())
  name      String   // E.g., "ZenoRadio Relay"
  host      String   // E.g., "stream.zeno.fm"
  port      Int
  mount     String?  // Optional mount point (for Icecast)
  username  String?  // Optional username (usually 'source')
  password  String
  type      String   // "ICECAST" or "SHOUTCAST"
  format    String   @default("MP3") // "MP3" or "AAC"
  bitrate   Int      @default(128)   // 64, 128, 192, 256, 320
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}


